{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_SHARED_LIBS": "ON",
        "ZLAY_BUILD_EXAMPLES": "ON",
        "ZLAY_BUILD_DRIVERS": "ON",
        "ZLAY_BUILD_RENDERER": "ON",
        "ZLAY_BUILD_SHADERS": "ON",
        "ZLAY_BUILD_OS": "ON",
        "ZLAY_HEADER_TEMPLATE_STYLE": "ifndef",
        "ZLAY_HEADER_TEMPLATE_INCLUDE": "zlay.h",
        "ZLAY_HEADER_TEMPLATE_EXTERN_C": "ON",
        "ZLAY_OS_BACKEND": "auto"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "clangd",
      "displayName": "Clangd IntelliSense",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/clangd",
      "cacheVariables": {
        "ZLAY_CLANGD_COPY_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-static",
      "displayName": "Debug Static",
      "inherits": "debug",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "release-static",
      "displayName": "Release Static",
      "inherits": "release",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "emscripten-base",
      "hidden": true,
      "inherits": "base",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF",
        "ZLAY_BUILD_EXAMPLES": "OFF",
        "ZLAY_BUILD_OS": "OFF"
      }
    },
    {
      "name": "emscripten-debug",
      "displayName": "Emscripten Debug",
      "inherits": "emscripten-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "emscripten-release",
      "displayName": "Emscripten Release",
      "inherits": "emscripten-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "clangd",
      "configurePreset": "clangd"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug-static",
      "configurePreset": "debug-static"
    },
    {
      "name": "release-static",
      "configurePreset": "release-static"
    },
    {
      "name": "emscripten-debug",
      "configurePreset": "emscripten-debug"
    },
    {
      "name": "emscripten-release",
      "configurePreset": "emscripten-release"
    }
  ],
  "testPresets": []
}
